# Article 3 — ChatGPT × Claude Second Opinion MCP App
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored.

# --------------------------------------------------------------------
# Anthropic API key for spec-002+ (Claude API 呼び出しに必須)
# --------------------------------------------------------------------
# 取得元: https://console.anthropic.com/settings/keys
# ⚠️ これは "Claude Max" 月額サブスクとは別の、従量課金の API キーです。
#    Max プランを契約していても API 課金は別扱いになります。
ANTHROPIC_API_KEY=sk-ant-api03-...

# --------------------------------------------------------------------
# DNS rebinding 保護の回避 (spec-004+ で cloudflared 公開時に使用)
# --------------------------------------------------------------------
# cloudflared トンネルで発行された HTTPS ホスト名をカンマ区切りで列挙。
# 例: ALLOWED_HOSTS="mechanisms-birds-terminal-blues.trycloudflare.com"
# 未設定の場合は localhost/127.0.0.1 のみ許可される (default 安全側)。
ALLOWED_HOSTS=

# --------------------------------------------------------------------
# サーバーのバインドホスト (通常は変更不要)
# --------------------------------------------------------------------
# MCP_HOST=127.0.0.1

# --------------------------------------------------------------------
# サーバーのポート (通常は変更不要)
# --------------------------------------------------------------------
# PORT=3001

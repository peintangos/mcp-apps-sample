# Article 3 — ChatGPT × Claude Second Opinion MCP App
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored.

# --------------------------------------------------------------------
# Anthropic API key for spec-002+ (Claude API 呼び出しに必須)
# --------------------------------------------------------------------
# 取得元: https://console.anthropic.com/settings/keys
# ⚠️ これは "Claude Max" 月額サブスクとは別の、従量課金の API キーです。
#    Max プランを契約していても API 課金は別扱いになります。
ANTHROPIC_API_KEY=sk-ant-api03-...

# --------------------------------------------------------------------
# DNS rebinding 保護の回避 (cloudflared / Fly.io 等で公開する時に必須)
# --------------------------------------------------------------------
# 公開ホスト名をカンマ区切りで列挙。
# cloudflared 例: "mechanisms-birds-terminal-blues.trycloudflare.com"
# Fly.io 例:      "article-3-claude-second-opinion.fly.dev"
# 未設定の場合は localhost/127.0.0.1 のみ許可される (default 安全側)。
ALLOWED_HOSTS=

# --------------------------------------------------------------------
# OAuth 2.1 認可 (公開ホスティング時に必須、spec-006)
# --------------------------------------------------------------------
# MCP の Custom Connector は API Key 認証を提供しないので、サーバー自身が
# OAuth 2.1 authorization server を兼ねる。`OAUTH_OWNER_PASSWORD` をセット
# すると OAuth モードで起動し、/.well-known/oauth-authorization-server、
# /register、/authorize、/token、/mcp の認可ミドルウェアが有効化される。
# 未設定時はローカル開発モードとなり /mcp は無保護 (basic-host からそのまま
# 叩けるように)。起動時に警告が出る。
#
# OAUTH_OWNER_PASSWORD は同意画面で自分が入力するパスワード。
# `openssl rand -hex 16` などで生成して、絶対に公開しない。
OAUTH_OWNER_PASSWORD=

# OAUTH_ISSUER は OAuth ディスカバリの `issuer` に使う base URL。
# Fly.io 例: https://article-3-claude-second-opinion.fly.dev
# 未設定の場合は受け取ったリクエストの Host ヘッダから自動導出する。
OAUTH_ISSUER=

# --------------------------------------------------------------------
# サーバーのバインドホスト (通常は変更不要)
# --------------------------------------------------------------------
# MCP_HOST=127.0.0.1

# --------------------------------------------------------------------
# サーバーのポート (通常は変更不要)
# --------------------------------------------------------------------
# PORT=3001
